# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# ── backend/.env  (add these lines) ──────────────────────────────────────────

# Key 1 — you already have this
GROQ_API_KEY=gsk_your_first_key_here

# Key 2 — sign up at console.groq.com with youremail+groq2@gmail.com
GROQ_API_KEY_2=gsk_your_second_key_here

# Key 3 — sign up with youremail+groq3@gmail.com  (optional, cuts time further)
GROQ_API_KEY_3=gsk_your_third_key_here

# Supabase (already set, no change needed)
SUPABASE_URL=https://pjxrjytcurqrmbuhgyoi.supabase.co
SUPABASE_KEY=your_supabase_key_here
SUPABASE_TABLE=ai_tools